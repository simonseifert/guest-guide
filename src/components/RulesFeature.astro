---
import Icon from './Icon.astro';
import { withFallback, type Lang } from '../i18n/ui';

interface Props {
  href: string;
  title: string;
  desc?: string;
  lang: Lang;
}
const { href, title, desc, lang } = Astro.props;
const eyebrow: Partial<Record<Lang, string>> = {
  en: 'Read this first',
  de: 'Bitte zuerst lesen',
  hr: 'Pročitajte prvo',
  it: 'Da leggere per primo',
};
---
<a class="rules-feature" href={href}>
  <span class="icon-tile"><Icon name="house" size={28} /></span>
  <span class="meta">
    <div class="eyebrow">{withFallback(eyebrow, lang)}</div>
    <h3>{title}</h3>
    {desc && <div class="desc">{desc}</div>}
  </span>
  <Icon name="arrow" size={16} class="arrow" />
</a>
