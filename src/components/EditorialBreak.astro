---
import type { Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

// v1: no fictional quote — just the photo + minimal eyebrow until we have a real Selma quote.
const copy: Record<Lang, { eyebrow: string; line: string; author: string }> = {
  hr: { eyebrow: '— Selma, domaćica', line: 'Naša drvena koliba puna je čuda i iznenađenja.', author: 'Dobrodošli u kraljevstvo.' },
  en: { eyebrow: '— Selma, your host', line: 'Our log cabin is full of wonders and surprises.', author: 'Welcome to the kingdom.' },
  de: { eyebrow: '— Selma, Gastgeberin', line: 'Unsere Blockhütte steckt voller Wunder und Überraschungen.', author: 'Willkommen im Königreich.' },
  it: { eyebrow: '— Selma, padrona di casa', line: 'La nostra baita è piena di meraviglie e sorprese.', author: 'Benvenuti nel regno.' },
};
const c = copy[lang];
---
<div class="editorial">
  <div class="photo" aria-hidden="true"></div>
  <div class="copy">
    <p class="eyebrow">{c.eyebrow}</p>
    <blockquote>{c.line}</blockquote>
    <p class="author">{c.author}</p>
  </div>
</div>
