---
import Icon from './Icon.astro';
import type { IconName } from './icons';
import { withFallback, type Lang } from '../i18n/ui';

interface Props {
  href: string;
  icon: IconName;
  title: string;
  summary?: string;
  safety?: boolean;
  lang: Lang;
}
const { href, icon, title, summary, safety = false, lang } = Astro.props;
const safetyLabel: Partial<Record<Lang, string>> = {
  en: 'Safety first',
  de: 'Vorsicht',
  hr: 'Oprez',
  it: 'Attenzione',
};
---
<a class:list={['row', safety && 'safety']} href={href}>
  <span class="icon-tile"><Icon name={icon} size={26} /></span>
  <span class="body">
    <h4>{title}</h4>
    {summary && <span class="summary">{summary}</span>}
    {safety && (
      <span class="safety-flag">
        <Icon name="warn" size={10} />
        {withFallback(safetyLabel, lang)}
      </span>
    )}
  </span>
  <Icon name="arrow" size={14} class="arrow" />
</a>
