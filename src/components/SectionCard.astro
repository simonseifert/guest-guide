---
interface Props {
  href: string;
  icon: string;
  title: string;
  summary?: string;
  safetyCritical?: boolean;
}
const { href, icon, title, summary, safetyCritical = false } = Astro.props;
---
<a
  href={href}
  class:list={[
    'group relative flex gap-4 rounded-2xl border bg-cream-50 p-5 transition',
    'hover:-translate-y-0.5 hover:shadow-lg hover:shadow-forest-900/10',
    safetyCritical
      ? 'border-bark-500/25 hover:border-bark-500/50'
      : 'border-forest-700/10 hover:border-forest-700/30'
  ]}
>
  <span class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-forest-700/8 text-2xl">
    {icon}
  </span>
  <div class="flex-1 min-w-0">
    <h3 class="font-display text-xl leading-tight text-forest-700">
      {title}
    </h3>
    {summary && (
      <p class="mt-1 text-sm text-bark-900/70 leading-snug">
        {summary}
      </p>
    )}
  </div>
  <svg class="absolute right-4 top-1/2 -translate-y-1/2 text-forest-700/30 transition group-hover:text-forest-700 group-hover:translate-x-0.5" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
    <path d="M5 3l4 4-4 4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>
</a>
