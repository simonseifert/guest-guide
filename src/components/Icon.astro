{name === 'pine' && (
  <svg viewBox="0 0 32 32" {...common}>
    <path d="M16 4 L10 13 H13 L8 21 H13 L7 28 H25 L19 21 H24 L19 13 H22 Z"/>
    <path d="M16 28 V25"/>
  </svg>
)}
{name === 'phone' && (
  <svg viewBox="0 0 32 32" {...common}>
    <path d="M7 5 H11 L13 11 L10 13 C 11 17, 15 21, 19 22 L21 19 L27 21 V25 C27 26.5, 26 28, 24 28 C 14 28, 4 18, 4 8 C 4 6, 5.5 5, 7 5 Z"/>
  </svg>
