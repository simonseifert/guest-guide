)}
{name === 'oven' && (
  <svg viewBox="0 0 32 32" {...common}>
    <rect x="5" y="4" width="22" height="24" rx="1.5"/>
    <path d="M5 11 H27"/>
    <circle cx="9" cy="7.5" r="0.6" fill="currentColor"/>
    <circle cx="13" cy="7.5" r="0.6" fill="currentColor"/>
    <circle cx="17" cy="7.5" r="0.6" fill="currentColor"/>
    <circle cx="22" cy="7.5" r="1.2"/>
    <rect x="9" y="14" width="14" height="11" rx="0.6"/>
  </svg>
)}
{name === 'water' && (
  <svg viewBox="0 0 32 32" {...common}>
    <path d="M16 4 C 16 4, 9 13, 9 19 C 9 23, 12 26, 16 26 C 20 26, 23 23, 23 19 C 23 13, 16 4, 16 4 Z"/>
    <path d="M13 19 C 13 21, 14.5 22.5, 16 22.5"/>
  </svg>
)}
{name === 'audio' && (
  <svg viewBox="0 0 32 32" {...common}>
    <rect x="4" y="6" width="24" height="20" rx="2"/>
