{name === 'pin' && (
  <svg viewBox="0 0 16 16" {...{ ...common, 'stroke-width': 1.5 }}>
    <path d="M8 14 C 5 11, 3 8, 3 6 C 3 3, 5 1.5, 8 1.5 C 11 1.5, 13 3, 13 6 C 13 8, 11 11, 8 14 Z"/>
    <circle cx="8" cy="6" r="1.6"/>
  </svg>
)}
{name === 'qr' && (
  <svg viewBox="0 0 24 24" {...{ ...common, 'stroke-width': 1.6 }}>
    <rect x="4" y="4" width="6" height="6" rx="1"/>
    <rect x="14" y="4" width="6" height="6" rx="1"/>
    <rect x="4" y="14" width="6" height="6" rx="1"/>
    <path d="M14 14 H17 V17 H14 Z M19 14 H20 M14 19 H15 M17 19 H20 M19 17 V20"/>
  </svg>
