---
/**
 * Custom monochrome line-icon set for Kraljica Šume.
 * Stroke style matches the Claude Design mockup (1.4px, round caps/joins).
 * Use via: <Icon name="jacuzzi" /> or <Icon name="wifi" size={20} />
 */
import type { IconName } from './icons';

interface Props {
  name: IconName;
  size?: number;
  strokeWidth?: number;
  class?: string;
}
const { name, size = 24, strokeWidth = 1.4, class: className = '' } = Astro.props;
const common = {
  width: size,
  height: size,
  fill: 'none',
  stroke: 'currentColor',
  'stroke-width': strokeWidth,
  'stroke-linecap': 'round',
  'stroke-linejoin': 'round',
  class: className,
  'aria-hidden': 'true',
};
---
{name === 'antlers' && (
  <svg viewBox="0 0 24 24" {...common}>
    <path d="M12 22 V13"/>
    <path d="M12 13 C 9 11, 7 8, 6.5 4 C 8 5, 9.5 6, 11 8"/>
    <path d="M12 13 C 15 11, 17 8, 17.5 4 C 16 5, 14.5 6, 13 8"/>
    <path d="M9 9 C 7.5 9, 6 8, 5 7"/>
    <path d="M15 9 C 16.5 9, 18 8, 19 7"/>
  </svg>
)}
{name === 'wifi' && (
  <svg viewBox="0 0 24 24" stroke-width={1.6} {...{ ...common, 'stroke-width': 1.6 }}>
    <path d="M2 9 C 8 3, 16 3, 22 9"/>
    <path d="M5.5 12.5 C 9.5 8.5, 14.5 8.5, 18.5 12.5" opacity="0.7"/>
    <path d="M9 16 C 11 14, 13 14, 15 16" opacity="0.5"/>
    <circle cx="12" cy="19.5" r="1.4" fill="currentColor"/>
  </svg>
)}
{name === 'house' && (
  <svg viewBox="0 0 32 32" {...common}>
    <path d="M4 15 L16 5 L28 15"/>
    <path d="M7 13 V26 H25 V13"/>
    <path d="M22 9 V5 H24.5 V11"/>
    <path d="M13 26 V19 H19 V26"/>
  </svg>
)}
{name === 'jacuzzi' && (
  <svg viewBox="0 0 32 32" {...common}>
    <path d="M4 16 H28"/>
    <path d="M5 16 V22 C5 24, 6 25, 8 25 H24 C26 25, 27 24, 27 22 V16"/>
    <path d="M10 12 C 10 10, 12 10, 12 12 C 12 14, 10 14, 10 16"/>
    <path d="M16 11 C 16 9, 18 9, 18 11 C 18 13, 16 13, 16 15"/>
    <path d="M22 12 C 22 10, 24 10, 24 12 C 24 14, 22 14, 22 16"/>
  </svg>
)}
{name === 'sauna' && (
  <svg viewBox="0 0 32 32" {...common}>
    <path d="M5 26 H27"/>
    <rect x="7" y="14" width="18" height="12" rx="1"/>
    <path d="M11 10 C 12 8, 11 6, 12 4"/>
    <path d="M16 10 C 17 8, 16 6, 17 4"/>
    <path d="M21 10 C 22 8, 21 6, 22 4"/>
  </svg>
)}
{name === 'grill' && (
  <svg viewBox="0 0 32 32" {...common}>
    <ellipse cx="16" cy="18" rx="12" ry="3"/>
    <path d="M4 18 V21 C4 23, 10 25, 16 25 C22 25, 28 23, 28 21 V18"/>
    <path d="M11 14 C 11 11, 13 11, 13 9 C 14 11, 16 11, 16 14"/>
    <path d="M17 13 C 17 10, 19 10, 19 8 C 20 10, 22 10, 22 13"/>
  </svg>
)}
{name === 'tv' && (
  <svg viewBox="0 0 32 32" {...common}>
    <rect x="4" y="7" width="24" height="16" rx="2"/>
    <path d="M11 28 L16 23 L21 28"/>
    <path d="M9 11 L14 13 L9 15 Z" fill="currentColor" opacity="0.15"/>
  </svg>
)}
{name === 'coffee' && (
  <svg viewBox="0 0 32 32" {...common}>
