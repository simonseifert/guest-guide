  </svg>
)}
{name === 'caret' && (
  <svg viewBox="0 0 10 10" {...{ ...common, 'stroke-width': 1.5 }}>
    <path d="M2 4 L5 7 L8 4"/>
  </svg>
)}
{name === 'warn' && (
  <svg viewBox="0 0 12 12" stroke="none" fill="currentColor" width={size} height={size} class={className} aria-hidden="true">
    <path d="M6 1 L11 10 H1 Z M6 4 V7 M6 8.5 V9"/>
  </svg>
)}
{name === 'external' && (
  <svg viewBox="0 0 12 12" {...{ ...common, 'stroke-width': 1.5 }}>
    <path d="M3 9 L9 3 M5 3 H9 V7"/>
  </svg>
)}
