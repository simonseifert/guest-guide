---
// Static root redirector — picks language client-side from
// localStorage > navigator.language > PROPERTY.defaultLanguage.
import { PROPERTY } from '../config/property';
const supported = PROPERTY.languages;
const fallback = PROPERTY.defaultLanguage;
---
<!doctype html>
<html lang={fallback}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{PROPERTY.brand.name}</title>
    <meta http-equiv="refresh" content={`0; url=/${fallback}`} />
    <script define:vars={{ supported, fallback }}>
      (() => {
        const stored = localStorage.getItem('guest-guide-lang');
        let lang = supported.includes(stored ?? '') ? stored : null;
        if (!lang) {
          const langs = (navigator.languages?.length ? navigator.languages : [navigator.language]) ?? [];
          for (const l of langs) {
            const code = (l ?? '').toLowerCase().split('-')[0];
            if (supported.includes(code)) { lang = code; break; }
          }
        }
        window.location.replace(`/${lang ?? fallback}`);
      })();
    </script>
    <style>
      body { background: #f5efe3; color: #2f4a3a; font-family: system-ui, sans-serif; display: grid; place-items: center; height: 100vh; margin: 0; }
      a { color: #2f4a3a; }
    </style>
  </head>
  <body>
    <p>Loading… <a href={`/${fallback}`}>Open guide</a></p>
  </body>
</html>
